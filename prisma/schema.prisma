// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== МОДЕЛИ ====================

// Категория техники (Экскаваторы, Краны, Погрузчики и т.д.)
model Category {
  id          Int       @id @default(autoincrement())
  name        String    // Название категории (напр. "Экскаваторы")
  slug        String    @unique // URL-friendly идентификатор (напр. "excavators")
  description String?   // Описание категории для SEO
  seoTextBottom String? @db.Text // SEO-текст для отображения внизу страницы категории
  imageUrl    String?   // URL изображения категории
  
  // Настройки фильтров для этой категории
  // Массив ключей доступных фильтров: ["liftingCapacity", "boomLength", "bucketVolume", "diggingDepth", "operatingWeight"]
  availableFilters Json @default("[]")
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Связь с техникой
  machines    Machine[]
  
  // EAV-атрибуты категории
  attributes  CategoryAttribute[]
  
  // Кросс-продажи: связанные категории (self-referential many-to-many)
  relatedFrom RelatedCategory[] @relation("RelatedFrom") // Категории, которые ссылаются на эту
  relatedTo   RelatedCategory[] @relation("RelatedTo")   // Категории, на которые ссылается эта
  
  @@map("categories")
}

// Связь кросс-продаж между категориями (для системы рекомендаций)
model RelatedCategory {
  id               Int      @id @default(autoincrement())
  sourceCategoryId Int      // Исходная категория (напр. "Краны")
  targetCategoryId Int      // Целевая категория для рекомендаций (напр. "Манипуляторы")
  
  sourceCategory   Category @relation("RelatedTo", fields: [sourceCategoryId], references: [id], onDelete: Cascade)
  targetCategory   Category @relation("RelatedFrom", fields: [targetCategoryId], references: [id], onDelete: Cascade)
  
  createdAt        DateTime @default(now())
  
  @@unique([sourceCategoryId, targetCategoryId]) // Уникальная связь между парой категорий
  @@index([sourceCategoryId])
  @@index([targetCategoryId])
  @@map("related_categories")
}

// Единица техники
model Machine {
  id          Int       @id @default(autoincrement())
  title       String    // Название (напр. "Экскаватор JCB JS220")
  slug        String    @unique // URL-friendly (напр. "jcb-js220")
  
  // Связь с категорией
  categoryId  Int
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  // Цены
  shiftPrice  Decimal   @db.Decimal(10, 2) // Цена за смену (8 часов)
  hourlyPrice Decimal?  @db.Decimal(10, 2) // Цена за час (опционально)
  
  // Характеристики (JSON, т.к. у разной техники разные параметры)
  // Например: {"weight": "22 т", "bucketVolume": "1.2 м³", "reach": "9.5 м"}
  specs       Json      @default("{}")
  
  // Контент
  description String?   @db.Text // Полное описание для страницы
  imageUrl    String?   // Главное фото
  images      String[]  // Галерея фото (массив URL)
  
  // Бейджи и дополнительные материалы
  badges      Json      @default("[]") // Массив бейджей: ["owner", "hit", "new", "sale"]
  loadChartUrl String?  // Ссылка на грузовысотную схему (PDF или изображение)
  
  // Параметры для фильтрации (краны и спецтехника)
  liftingCapacity Float?   // Грузоподъемность в тоннах
  boomLength      Float?   // Длина стрелы в метрах
  bucketVolume    Float?   // Объем ковша в м³
  diggingDepth    Float?   // Глубина копания в метрах
  operatingWeight Float?   // Эксплуатационная масса в тоннах
  isAllTerrain    Boolean  @default(false) // Вездеход (true) или Шоссейник (false)
  
  // Флаги
  isFeatured  Boolean   @default(false) // Показывать на главной
  isAvailable Boolean   @default(true)  // Доступна для аренды
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // EAV-атрибуты техники
  attributes  ProductAttributeValue[]
  
  @@index([categoryId])
  @@index([isFeatured])
  @@index([isAvailable])
  @@index([liftingCapacity])
  @@index([boomLength])
  @@index([bucketVolume])
  @@index([diggingDepth])
  @@index([operatingWeight])
  @@index([isAllTerrain])
  @@map("machines")
}

// Заявка на аренду
model Lead {
  id        Int        @id @default(autoincrement())
  
  // Контактные данные
  name      String     // Имя клиента
  phone     String     // Телефон (обязательно)
  email     String?    // Email (опционально)
  
  // Детали заявки
  machine   String?    // Название техники (если заявка со страницы товара)
  interest  String?    // Интерес клиента (напр. "Экскаватор", "Автокран")
  message   String?    @db.Text // Комментарий клиента
  source    String?    // Откуда пришла заявка (форма, звонок и т.д.)
  
  // Дополнительные детали для кранов и спецтехники
  taskType  String?    // Тип работ: Монтаж, Погрузка, Земляные работы и т.д.
  weight    String?    // Вес груза (например "5т")
  height    String?    // Высота подъема (например "20м")
  
  // Статус обработки
  status    LeadStatus @default(NEW)
  
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  
  @@index([status])
  @@index([createdAt])
  @@map("leads")
}

// Статусы заявки
enum LeadStatus {
  NEW        // Новая заявка
  PROCESSING // В обработке
  COMPLETED  // Завершена (договор заключен)
  CANCELLED  // Отменена
}

// Настройки компании (singleton - одна запись)
model CompanySettings {
  id          Int       @id @default(1)
  aboutImage  String?   // Фото для секции "О компании"
  updatedAt   DateTime  @updatedAt
  
  @@map("company_settings")
}

// Документы (лицензии, допуски и т.д.)
model Document {
  id        Int       @id @default(autoincrement())
  title     String    // Название документа
  number    String?   // Номер документа
  imageUrl  String?   // Скан/фото документа
  sortOrder Int       @default(0) // Порядок сортировки
  isActive  Boolean   @default(true) // Показывать на сайте
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  @@map("documents")
}

// Администратор системы
model AdminUser {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  passwordHash String
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  @@map("admin_users")
}

// Настройки сайта (singleton - одна запись с id=1)
model SiteSettings {
  id           Int       @id @default(1)
  
  // Контактные данные
  phone        String    // Основной телефон
  email        String    // Email для связи
  address      String    // Адрес офиса
  workingHours String    // Режим работы
  
  // Мессенджеры
  telegramUrl  String?   // Ссылка на Telegram
  whatsappUrl  String?   // Ссылка на WhatsApp
  
  // Карта
  mapIframe    String?   @db.Text // HTML код для встраивания карты
  
  // Документы
  contractUrl  String?   // Ссылка на PDF типового договора
  
  updatedAt    DateTime  @updatedAt
  
  @@map("site_settings")
}

// Отзывы клиентов
model Review {
  id        Int       @id @default(autoincrement())
  author    String    // Имя клиента или название компании
  role      String?   // Должность (напр. "Гл. инженер ООО СтройТрест")
  text      String    @db.Text // Текст отзыва
  rating    Int       @default(5) // Оценка (1-5)
  isVisible Boolean   @default(true) // Показывать на сайте
  scanUrl   String?   // Ссылка на скан благодарственного письма (IMG/PDF)
  
  createdAt DateTime  @default(now())
  
  @@map("reviews")
}

// ==================== EAV-АТРИБУТЫ ====================

// Атрибут (характеристика) техники
model Attribute {
  id          Int      @id @default(autoincrement())
  name        String   // Название: "Грузоподъемность", "Длина стрелы"
  slug        String   @unique // Для URL фильтров: "lifting_capacity"
  type        String   // "number", "string", "select" (тип данных)
  unit        String?  // "т", "м", "м³" (единица измерения)
  
  categories  CategoryAttribute[]
  values      ProductAttributeValue[]
  
  @@map("attributes")
}

// Привязка атрибута к категории
model CategoryAttribute {
  id          Int       @id @default(autoincrement())
  categoryId  Int
  attributeId Int
  isFilter    Boolean   @default(false) // Использовать ли в фильтрах каталога?
  showInCard  Boolean   @default(false) // Показывать ли на карточке товара?
  order       Int       @default(0)     // Порядок сортировки в админке/фильтрах

  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([categoryId, attributeId]) // Атрибут уникален для категории
  @@map("category_attributes")
}

// Значение атрибута для конкретной единицы техники
model ProductAttributeValue {
  id          String    @id @default(cuid())
  machineId   Int
  attributeId Int
  
  valueNumber Float?    // Если тип number
  valueString String?   // Если тип string/select
  
  machine     Machine   @relation(fields: [machineId], references: [id], onDelete: Cascade)
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([machineId, attributeId])
  @@index([attributeId])
  @@map("product_attribute_values")
}
